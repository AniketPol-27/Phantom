# ============================================================
# Phantom MCP Server - Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your values
# Never commit .env to git

# ----- Server Configuration -----
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO

# ----- FHIR Server (for local dev / fallback) -----
# In production, FHIR URL comes from SHARP context per request
DEFAULT_FHIR_BASE_URL=https://hapi.fhir.org/baseR4

# ----- External APIs -----
# RxNorm API does not require a key, but we set timeout
RXNORM_API_BASE=https://rxnav.nlm.nih.gov/REST
RXNORM_TIMEOUT_SECONDS=10

# OpenFDA does not require a key for basic use
OPENFDA_API_BASE=https://api.fda.gov
OPENFDA_TIMEOUT_SECONDS=10

# ----- Patient Model Cache -----
MODEL_CACHE_TTL_SECONDS=1800

# ----- MCP Server Auth (optional, for production) -----
# Bearer token that Prompt Opinion will use to authenticate
# Leave empty for unauthenticated dev
MCP_AUTH_TOKEN=

# ----- Development -----
# Set to true to enable verbose logging and dev features
DEV_MODE=true